#!/usr/bin/env bash
#
# log-monitor - Dnevni sistemski log monitoring sa Telegram notifikacijama
#
# Analizira sistemske logove (journal, SSH, disk, memorija, servisi),
# filtrira poznati šum, i šalje Telegram obaveštenje SAMO ako
# postoji nešto zabrinjavajuće. Tišina = sve OK.
#
# Korišćenje:
#   log-monitor            # Pokreni analizu i pošalji ako treba
#   log-monitor --dry-run  # Samo prikaži prikupljene podatke i OpenCode analizu
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOG_DIR="/var/log/notifierbot"
LOG_FILE="$LOG_DIR/log-monitor.log"
DRY_RUN=false
WEEKLY=false
SINCE="24 hours ago"
SERVER_NAME="labubu"

# Parse argumenata
for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        --weekly) WEEKLY=true ;;
        *) echo "Nepoznat argument: $arg" >&2; exit 1 ;;
    esac
done

# Logging
log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    if [[ -d "$LOG_DIR" ]]; then
        echo "$msg" >> "$LOG_FILE"
    fi
    if [[ "$DRY_RUN" == true ]]; then
        echo "$msg" >&2
    fi
}

# Error handler - šalje notifikaciju u Telegram
send_error() {
    local error_msg="$1"
    log "GREŠKA: $error_msg"
    if [[ "$DRY_RUN" == false ]]; then
        php -r "
            require_once '$SCRIPT_DIR/NotifierBot.php';
            NotifierBot::send('error', 'Log Monitor greška: ' . \$argv[1]);
        " -- "$error_msg" 2>/dev/null || true
    fi
}

trap 'send_error "Skripta prekinuta na liniji $LINENO"' ERR

# --- 1. Učitavanje .env ---
log "Učitavanje konfiguracije..."

ENV_FILE="$SCRIPT_DIR/.env"
if [[ ! -f "$ENV_FILE" ]]; then
    send_error ".env fajl ne postoji u $SCRIPT_DIR"
    exit 1
fi

TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

while IFS='=' read -r key value; do
    key=$(echo "$key" | xargs)
    value=$(echo "$value" | xargs)
    [[ -z "$key" || "$key" == \#* ]] && continue
    case "$key" in
        TELEGRAM_BOT_TOKEN) TELEGRAM_BOT_TOKEN="$value" ;;
        TELEGRAM_CHAT_ID) TELEGRAM_CHAT_ID="$value" ;;
    esac
done < "$ENV_FILE"

missing=""
[[ -z "$TELEGRAM_BOT_TOKEN" ]] && missing+="TELEGRAM_BOT_TOKEN "
[[ -z "$TELEGRAM_CHAT_ID" ]] && missing+="TELEGRAM_CHAT_ID "

if [[ -n "$missing" ]]; then
    send_error "Nedostaju varijable u .env: $missing"
    exit 1
fi

log "Konfiguracija učitana."

# --- 2. Prikupljanje podataka ---
log "Prikupljanje sistemskih podataka za poslednjih 24h..."

# Poznati šum koji treba ignorisati
NOISE_PATTERNS="pam_unix\(cron:session\)|systemd-tmpfiles|snapd\.|dbus-daemon.*Activating|avahi-daemon"

# 2.1 Journal greške (priority 0-3: emerg, alert, crit, err)
JOURNAL_ERRORS=$(journalctl --priority=0..3 --since "$SINCE" --no-pager -q 2>/dev/null | grep -vE "$NOISE_PATTERNS" | head -100 || true)
JOURNAL_ERROR_COUNT=$(echo "$JOURNAL_ERRORS" | grep -c . || true)

# 2.2 SSH neuspeli pokušaji
SSH_FAILURES=$(journalctl -u ssh --since "$SINCE" --no-pager -q 2>/dev/null | grep -iE "Failed|Invalid user" | head -100 || true)
SSH_FAILURE_COUNT=$(echo "$SSH_FAILURES" | grep -c . || true)

# 2.3 Failed servisi
FAILED_SERVICES=$(systemctl list-units --state=failed --no-legend 2>/dev/null || true)
FAILED_SERVICE_COUNT=$(echo "$FAILED_SERVICES" | grep -c . || true)

# Restart log za poslednja 24h
SERVICE_RESTARTS=$(journalctl --since "$SINCE" --no-pager -q 2>/dev/null | grep -iE "Started|Stopped|Restarting" | grep -vE "$NOISE_PATTERNS" | head -50 || true)

# 2.4 OOM killer
OOM_EVENTS=$(journalctl --since "$SINCE" --no-pager -q 2>/dev/null | grep -iE "oom|out of memory" | head -20 || true)
OOM_COUNT=$(echo "$OOM_EVENTS" | grep -c . || true)

# 2.5 Kernel greške
KERNEL_ERRORS=$(journalctl -k --priority=0..3 --since "$SINCE" --no-pager -q 2>/dev/null | head -50 || true)
KERNEL_ERROR_COUNT=$(echo "$KERNEL_ERRORS" | grep -c . || true)

# 2.6 Disk prostor
DISK_USAGE=$(df -h / 2>/dev/null | tail -1)
DISK_PERCENT=$(echo "$DISK_USAGE" | awk '{print $5}' | tr -d '%')
INODE_USAGE=$(df -i / 2>/dev/null | tail -1)
INODE_PERCENT=$(echo "$INODE_USAGE" | awk '{print $5}' | tr -d '%')

# 2.7 Memorija
MEMORY_INFO=$(free -h 2>/dev/null)
SWAP_LINE=$(free 2>/dev/null | grep -i swap)
SWAP_TOTAL=$(echo "$SWAP_LINE" | awk '{print $2}')
SWAP_USED=$(echo "$SWAP_LINE" | awk '{print $3}')
if [[ "$SWAP_TOTAL" -gt 0 ]] 2>/dev/null; then
    SWAP_PERCENT=$((SWAP_USED * 100 / SWAP_TOTAL))
else
    SWAP_PERCENT=0
fi

# 2.8 Unattended upgrades
UPGRADES=$(journalctl -u unattended-upgrades --since "$SINCE" --no-pager -q 2>/dev/null | head -30 || true)

log "Prikupljeno: journal=$JOURNAL_ERROR_COUNT, ssh=$SSH_FAILURE_COUNT, failed_svc=$FAILED_SERVICE_COUNT, oom=$OOM_COUNT, kernel=$KERNEL_ERROR_COUNT, disk=${DISK_PERCENT}%, swap=${SWAP_PERCENT}%"

# --- 3. Pre-check brzi izlaz ---
if [[ "$JOURNAL_ERROR_COUNT" -eq 0 ]] && \
   [[ "$SSH_FAILURE_COUNT" -lt 5 ]] && \
   [[ "$OOM_COUNT" -eq 0 ]] && \
   [[ "$KERNEL_ERROR_COUNT" -eq 0 ]] && \
   [[ "$FAILED_SERVICE_COUNT" -eq 0 ]] && \
   [[ "$DISK_PERCENT" -lt 80 ]] && \
   [[ "$SWAP_PERCENT" -lt 50 ]]; then
    log "Pre-check: Sve čisto. Nema potrebe za OpenCode analizom."
    if [[ "$DRY_RUN" == true ]]; then
        echo ""
        echo "========== PRE-CHECK: SVE OK =========="
        echo "Journal greške: $JOURNAL_ERROR_COUNT"
        echo "SSH neuspeli: $SSH_FAILURE_COUNT"
        echo "OOM eventi: $OOM_COUNT"
        echo "Kernel greške: $KERNEL_ERROR_COUNT"
        echo "Failed servisi: $FAILED_SERVICE_COUNT"
        echo "Disk: ${DISK_PERCENT}%"
        echo "Swap: ${SWAP_PERCENT}%"
        echo "======================================="
    fi
    if [[ "$WEEKLY" == true ]]; then
        UPTIME=$(uptime -p 2>/dev/null | sed 's/up //')
        LOAD=$(cat /proc/loadavg 2>/dev/null | awk '{print $1}')
        WEEKLY_MSG="✅ *Sistem je stabilan*

🖥️ Server: $SERVER_NAME
📅 $(TZ='Europe/Belgrade' date '+%d.%m.%Y %H:%M')
⏱️ Uptime: $UPTIME
💾 Disk: ${DISK_PERCENT}%
🔄 Swap: ${SWAP_PERCENT}%
📊 Load: $LOAD
🔐 SSH pokušaji: $SSH_FAILURE_COUNT
🚀 Svi servisi rade"
        log "Weekly: šaljem 'sve OK' poruku..."
        if [[ "$DRY_RUN" == true ]]; then
            echo ""
            echo "========== WEEKLY PORUKA =========="
            echo "$WEEKLY_MSG"
            echo "==================================="
        else
            php -r "
                require_once '$SCRIPT_DIR/NotifierBot.php';
                NotifierBot::send('monitor', file_get_contents('php://stdin'));
            " <<< "$WEEKLY_MSG" || send_error "Greška pri slanju weekly health poruke"
        fi
    fi
    exit 0
fi

    log "Pre-check: Pronađeni nalazi, šaljem OpenCode-u na analizu..."

# --- 4. Priprema podataka za OpenCode ---
REPORT="=== SISTEMSKI PODACI ZA POSLEDNJIH 24h ===
Server: $SERVER_NAME (Ubuntu 24.04)
Datum: $(TZ='Europe/Belgrade' date '+%d.%m.%Y %H:%M')

--- JOURNAL GREŠKE (priority 0-3) ---
Ukupno: $JOURNAL_ERROR_COUNT
$JOURNAL_ERRORS

--- SSH NEUSPELI POKUŠAJI ---
Ukupno: $SSH_FAILURE_COUNT
$SSH_FAILURES

--- SERVISI U GREŠKI ---
Trenutno failed: $FAILED_SERVICE_COUNT
$FAILED_SERVICES

Restartovi:
$SERVICE_RESTARTS

--- OOM EVENTI ---
Ukupno: $OOM_COUNT
$OOM_EVENTS

--- KERNEL GREŠKE ---
Ukupno: $KERNEL_ERROR_COUNT
$KERNEL_ERRORS

--- DISK ---
Root: $DISK_USAGE
Inodovi: $INODE_USAGE

--- MEMORIJA ---
$MEMORY_INFO
Swap korišćenje: ${SWAP_PERCENT}%

--- AŽURIRANJA (unattended-upgrades) ---
$UPGRADES"

if [[ "$DRY_RUN" == true ]]; then
    echo ""
    echo "========== PRIKUPLJENI PODACI =========="
    echo "$REPORT"
    echo "========================================"
    echo ""
fi

# --- 5. OpenCode trijaž ---
log "Pokrećem OpenCode analizu..."

PROMPT="Ti si sistem administrator. Analiziraj sledeće sistemske logove i odluči da li ima nešto zabrinjavajuće.

PRAVILA:
- Ako NEMA ničeg zabrinjavajućeg, odgovori SAMO jednom rečju: NISTA
- Ako IMA nečeg zabrinjavajućeg, napiši kratak izveštaj na srpskom (latinica) koristeći emoji indikatore:
  🔴 za kritično (pad servisa, kernel panic, OOM, disk >95%)
  🟡 za upozorenje (disk >85%, brute force SSH, česti restartovi)
  🟢 za info (ažuriranja, restartovi koji su se odmah oporavili)

ŠTA PRIJAVITI:
- Pad servisa koji se nije oporavio
- Disk popunjenost >85%
- OOM killer aktiviran
- Brute force SSH: >20 pokušaja sa istog IP ili >50 ukupno
- Kernel panic ili hardverske greške
- Neuspela sistemska ažuriranja

ŠTA NE PRIJAVLJIVATI (normalno ponašanje):
- Rutinske CRON sesije (pam_unix cron:session)
- Normalni SSH logini (Accepted)
- Servis koji se restartovao i odmah nastavio da radi
- <10 neuspelih SSH pokušaja (normalno skeniranje)
- systemd-tmpfiles, snapd, dbus-daemon, avahi-daemon poruke

FORMAT (ako prijavljivaš):
Samo stavke sa emoji indikatorima, jedna po redu. Kratko i jasno. Bez uvoda i zaključka. Telegram Markdown format (_italic_ za nazive servisa).

$REPORT"

RESPONSE=$(echo "$PROMPT" | opencode run --format json 2>/dev/null) || {
    send_error "OpenCode CLI greška pri analizi logova"
    exit 1
}

ANALYSIS=$(echo "$RESPONSE" | jq -r 'select(.type == "text") | .part.text') || {
    send_error "Greška pri parsiranju OpenCode odgovora"
    exit 1
}

if [[ -z "$ANALYSIS" ]]; then
    send_error "OpenCode vratio prazan odgovor"
    exit 1
fi

log "OpenCode analiza završena: ${#ANALYSIS} karaktera"

if [[ "$DRY_RUN" == true ]]; then
    echo "========== OPENCODE ANALIZA =========="
    echo "$ANALYSIS"
    echo "======================================"
fi

# --- 6. Provera da li treba slati ---
if [[ "$ANALYSIS" == "NISTA" ]] || [[ "$ANALYSIS" == "NIŠTA" ]]; then
    log "OpenCode kaže: NISTA zabrinjavajuće. Bez slanja."
    if [[ "$DRY_RUN" == true ]]; then
        echo ""
        echo ">>> OpenCode je odlučio da nema ničeg za prijavljivanje."
    fi
    exit 0
fi

log "OpenCode je pronašao nalaze. Pripremam Telegram poruku..."

# --- 7. Sanitizacija i slanje ---
# Sanitizacija Markdown-a za Telegram
ANALYSIS=$(php -r "
    \$text = file_get_contents('php://stdin');
    foreach (['_', '*'] as \$ch) {
        \$count = substr_count(\$text, \$ch);
        if (\$count % 2 !== 0) {
            \$text .= \$ch;
        }
    }
    echo \$text;
" <<< "$ANALYSIS")

FULL_MESSAGE="🔍 *SISTEMSKI IZVEŠTAJ*
🖥️ Server: $SERVER_NAME
📅 $(TZ='Europe/Belgrade' date '+%d.%m.%Y %H:%M')

$ANALYSIS"

if [[ "$DRY_RUN" == true ]]; then
    echo ""
    echo "========== TELEGRAM PORUKA =========="
    echo "$FULL_MESSAGE"
    echo "====================================="
    echo "Ukupno karaktera: ${#FULL_MESSAGE}"
    log "Dry-run završen"
    exit 0
fi

log "Slanje u Telegram..."

# Split i slanje (isti pattern kao gitlab-digest)
send_telegram_message() {
    local text="$1"
    php -r "
        \$text = file_get_contents('php://stdin');
        \$maxLen = 4000;

        if (mb_strlen(\$text) <= \$maxLen) {
            \$parts = [\$text];
        } else {
            \$parts = [];
            \$current = '';
            \$paragraphs = explode(\"\n\n\", \$text);

            foreach (\$paragraphs as \$para) {
                if (mb_strlen(\$current . \"\n\n\" . \$para) > \$maxLen && \$current !== '') {
                    \$parts[] = trim(\$current);
                    \$current = \$para;
                } else {
                    \$current .= (\$current !== '' ? \"\n\n\" : '') . \$para;
                }
            }
            if (\$current !== '') {
                \$parts[] = trim(\$current);
            }
        }

        \$total = count(\$parts);
        foreach (\$parts as \$i => \$part) {
            if (\$total > 1) {
                \$part .= \"\n\n📄 Deo \" . (\$i + 1) . '/' . \$total;
            }

            \$url = 'https://api.telegram.org/bot' . trim('$TELEGRAM_BOT_TOKEN') . '/sendMessage';
            \$ch = curl_init();
            curl_setopt_array(\$ch, [
                CURLOPT_URL => \$url,
                CURLOPT_POST => true,
                CURLOPT_POSTFIELDS => http_build_query([
                    'chat_id' => trim('$TELEGRAM_CHAT_ID'),
                    'text' => \$part,
                    'parse_mode' => 'Markdown',
                ]),
                CURLOPT_RETURNTRANSFER => true,
                CURLOPT_TIMEOUT => 10,
            ]);
            \$response = curl_exec(\$ch);
            \$httpCode = curl_getinfo(\$ch, CURLINFO_HTTP_CODE);
            curl_close(\$ch);

            if (\$httpCode !== 200) {
                fwrite(STDERR, \"Markdown parse failed (HTTP \$httpCode), retrying without parse_mode...\n\");
                \$ch = curl_init();
                curl_setopt_array(\$ch, [
                    CURLOPT_URL => \$url,
                    CURLOPT_POST => true,
                    CURLOPT_POSTFIELDS => http_build_query([
                        'chat_id' => trim('$TELEGRAM_CHAT_ID'),
                        'text' => \$part,
                    ]),
                    CURLOPT_RETURNTRANSFER => true,
                    CURLOPT_TIMEOUT => 10,
                ]);
                \$response = curl_exec(\$ch);
                \$httpCode = curl_getinfo(\$ch, CURLINFO_HTTP_CODE);
                curl_close(\$ch);
                if (\$httpCode !== 200) {
                    fwrite(STDERR, \"Telegram API greška (HTTP \$httpCode): \$response\n\");
                    exit(1);
                }
            }

            if (\$i < \$total - 1) {
                sleep(1);
            }
        }
        echo \"OK\";
    " <<< "$text"
}

result=$(send_telegram_message "$FULL_MESSAGE") || {
    send_error "Greška pri slanju izveštaja u Telegram"
    exit 1
}

if [[ "$result" == "OK" ]]; then
    log "Sistemski izveštaj uspešno poslat u Telegram"
else
    send_error "Neočekivan odgovor pri slanju: $result"
    exit 1
fi

log "Završeno."
